# ── LLM ──────────────────────────────────────────────────────────────────────
# Gemini via Google AI Studio (https://aistudio.google.com/apikey)
# Recommended model for Prompt Opinion: gemini-2.0-flash-lite
GOOGLE_API_KEY=

# ── CritCom auth (Prompt Opinion → agent) ────────────────────────────────────
# Set this in your Prompt Opinion agent configuration as the API key
CRITCOM_API_KEY=change-me-before-deploy
CRITCOM_API_KEY_SECONDARY=
# Set to "false" to disable enforcement during local dev only
CRITCOM_REQUIRE_API_KEY=true

# ── Agent runtime ─────────────────────────────────────────────────────────────
CRITCOM_LLM_MODEL=gemini-2.0-flash
CRITCOM_LLM_MAX_TOKENS=1024
CRITCOM_LLM_TEMPERATURE=0.0

# Public URL where Prompt Opinion will reach your agent (set after deployment)
CRITCOM_AGENT_URL=https://your-app.onrender.com

# Prompt Opinion FHIR context extension URI — do not change
CRITCOM_FHIR_EXTENSION_URI=https://promptopinion.ai/schemas/a2a/v1/fhir-context

LOG_LEVEL=INFO

# ── FHIR ──────────────────────────────────────────────────────────────────────
# Injected automatically by Prompt Opinion at runtime via FHIR context.
# Set these only for local testing against your own HAPI FHIR instance.
CRITCOM_FHIR_BASE_URL=http://localhost:8080/fhir
CRITCOM_FHIR_BEARER_TOKEN=
CRITCOM_FHIR_TIMEOUT_SECONDS=10
CRITCOM_FHIR_MAX_RETRIES=3

# ── ACR ack timeouts (minutes) ────────────────────────────────────────────────
CRITCOM_CAT1_ACK_TIMEOUT_MINUTES=1
CRITCOM_CAT2_ACK_TIMEOUT_MINUTES=1440
CRITCOM_CAT1_ESCALATION_LEVELS=2
CRITCOM_CAT2_ESCALATION_LEVELS=1
